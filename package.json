{
  "name": "project-alice",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server:dev": "nodemon server/index.js",
    "server:start": "node server/index.js",
    "server:dev:hosted": "nodemon --exec \"node --env-file=.env.local\" server/index.js",
    "server:start:hosted": "node --env-file=.env.local server/index.js",
    "db:init": "node server/db-init.js",
    "db:seed": "node server/db-seed.js",
    "db:seed:demo": "npm run db:seed && npm run db:seed:profile",
    "db:clear": "node server/db-clear.js",
    "db:seed:profile": "node server/db-seed-profile.js",
    "db:clear:profile": "node server/db-clear-profile.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ci": "vitest run --reporter=default --reporter=junit --outputFile.junit=test-results/vitest/results.xml",
    "lint": "eslint src tests server shared"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jsdom": "^29.0.2",
    "nodemon": "^3.1.14",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.80",
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/speed-insights": "^2.0.0",
    "better-sqlite3": "^12.9.0",
    "express": "^4.22.2",
    "jose": "^6.2.3",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  }
}
