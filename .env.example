# ─── Runtime ────────────────────────────────────────────────────────────────
# Controls which persistence mode the server uses.
# Values: "local" (default) | "hosted"
# Required in hosted mode; omit or leave blank for local development.
APP_RUNTIME=

# Optional: override the API server port (default: 3001)
PORT=

# ─── Local Development ──────────────────────────────────────────────────────
# Optional: override the SQLite database file path (default: data/alice.db)
ALICE_DB_PATH=

# ─── Hosted Mode — Supabase (server) ────────────────────────────────────────
# All three server variables below are required when APP_RUNTIME=hosted.
# Obtain SUPABASE_URL / ANON / SERVICE_ROLE from Supabase → Settings → API.
#
# Access tokens are verified against the project's JWKS endpoint
# (<SUPABASE_URL>/auth/v1/.well-known/jwks.json), so no shared HS256 secret
# is needed — Supabase signs tokens with an asymmetric key (ES256/RS256)
# and the middleware fetches the public key automatically.

# Your Supabase project URL.
SUPABASE_URL=

# Your Supabase anon/public key.
SUPABASE_ANON_KEY=

# !! SERVER ONLY — NEVER expose this key in browser code or VITE_ prefixed vars !!
# Your Supabase service role key. Has full database access; treat as a secret.
# This key bypasses Row Level Security and must never reach the frontend bundle.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Hosted Mode — Supabase (browser bundle) ────────────────────────────────
# All three VITE_* variables below are required at build time when shipping a
# hosted production bundle. The Vite plugin assertHostedFrontendEnv fails the
# build closed if any are missing in production. Re-use the same values as the
# corresponding server variables — do NOT put the service-role key or JWT
# secret here; those must never reach the browser.

# Same value as SUPABASE_URL; inlined into the Vite browser bundle.
VITE_SUPABASE_URL=

# Same value as SUPABASE_ANON_KEY; inlined into the Vite browser bundle.
VITE_SUPABASE_ANON_KEY=

# Verification-callback URL Supabase puts in confirmation emails.
# Typical value: https://<your-host>/?auth=callback
VITE_AUTH_EMAIL_REDIRECT_URL=
